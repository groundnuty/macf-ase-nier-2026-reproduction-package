{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.13.7/.schema/devbox.schema.json",
  "packages": [
    "bash@5.2",
    "coreutils@9.5",
    "gnused@4.9",
    "gawk@5.3",
    "jq@1.7",
    "gh@2.62",
    "gnumake@4.4",
    "diffutils@3.10",
    "python3@3.12"
  ],
  "shell": {
    "init_hook": [
      "echo \"Replication-package shell ready. Run 'make help' for targets.\""
    ],
    "scripts": {
      "tools": [
        "bash --version | head -1",
        "jq --version",
        "gh --version | head -1",
        "gawk --version | head -1",
        "gmake --version | head -1",
        "python3 --version"
      ]
    }
  }
}
